{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    // DOM is included so the server can typecheck @pm/shared's WebCrypto type surface
    // (CryptoKey, etc.) — the server itself never touches the DOM at runtime.
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "module": "ESNext",
    "moduleResolution": "Bundler"
  },
  "include": ["src"]
}
